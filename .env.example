# ============================================================
# Variables de entorno para el Asistente NSR-10
# ============================================================
# Copia este archivo como .env y reemplaza los valores.
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# ============================================================

# Región de AWS donde creaste los recursos de Bedrock y S3
AWS_REGION=us-east-1

# ID de la Knowledge Base creada en Amazon Bedrock
# Lo encuentras en: Consola AWS > Bedrock > Knowledge bases > tu KB > ID
KB_ID=TU_KNOWLEDGE_BASE_ID

# ARN o ID del modelo fundacional en Bedrock
# Ejemplo: arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-5-sonnet-20241022-v2:0
MODEL_ID=arn:aws:bedrock:us-east-1::foundation-model/TU_MODELO

# Nombre del bucket S3 donde se almacenan los PDFs de la NSR-10
# Lo encuentras en: Consola AWS > S3 > tu bucket > nombre
S3_BUCKET_NAME=nombre-de-tu-bucket
